# NewKet — Template de variables d'environnement
# Copiez ce fichier en '.env' et remplissez les valeurs réelles.
# Ne jamais committer le fichier .env dans Git !
#
# Pour trouver ces valeurs : https://supabase.com/dashboard -> votre projet -> Settings -> API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
